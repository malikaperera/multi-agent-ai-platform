FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY shared/ ./shared/
COPY apps/ ./apps/
COPY config/ ./config/
COPY memory/ ./memory/

ENV PYTHONPATH=/app
ENV DATA_DIR=/app/data
ENV MEMORY_DIR=/app/memory

VOLUME ["/app/data"]

CMD ["uvicorn", "apps.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
